# =============================================================================
# Variables d'environnement — microservice Cron Worker
# Copier en .env ou coller dans Render > Environment. Remplir les valeurs.
# Horaires et intervalles sont définis dans le code (toutes les 4 h par défaut).
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SECRET_KEY=

# --- Firebase (JSON base64 ou FIREBASE_SERVICE_ACCOUNT) ---
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# --- Redis (si QUEUE_WORKER_ENABLED=true) ---
REDIS_URL=redis://default:xxx@xxx.redislabs.com:12345

# --- Cron worker ---
CRON_PORT=10000
SHUTDOWN_HARD_TIMEOUT_MS=10000

# --- Activation des jobs (true/false) ---
ACTIVITY_JOB_ENABLED=true
ANALYTICS_SYNC_JOB_ENABLED=true
PAYME_MONTHLY_NEXT_PAYMENT_SYNC_ENABLED=true
SENIORITY_JOB_ENABLED=true
PROMO_REVERT_JOB_ENABLED=true
QUEUE_WORKER_ENABLED=true

# --- Options des jobs (optionnel) ---
ACTIVITY_JOB_LEASE_MS=7200000
ACTIVITY_JOB_PAGE_SIZE=200
ACTIVITY_JOB_CONCURRENCY=15
ANALYTICS_SYNC_JOB_LEASE_MS=7200000
PAYME_MONTHLY_NEXT_PAYMENT_SYNC_LEASE_MS=7200000
PAYME_MONTHLY_NEXT_PAYMENT_SYNC_DRY_RUN=false
SENIORITY_JOB_LEASE_MS=7200000
SENIORITY_JOB_PAGE_SIZE=200
SENIORITY_JOB_CONCURRENCY=15
QUEUE_POLL_TIMEOUT_SECONDS=5
JOB_TTL_SECONDS=86400

# --- PayMe ---
PAYME_SELLER_KEY=
PAYME_BASE_URL=https://live.payme.io/api/

# --- Twilio (queue worker SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
