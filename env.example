# --- Server ---
NODE_ENV=development
PORT=3000

# --- Firebase Admin ---
# Option A (recommandé sur Render): JSON string
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}'

# Option B: fichier présent sur le disque (ex: serviceAccountKey.json)
# FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Option C: JSON string alternative (compat)
# FIREBASE_SERVICE_ACCOUNT_JSON=...
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=...

# --- Securden ---
SECURDEN_AUTH_TOKEN=changeme
# SECURDEN_BASE_URL=https://olimservice.securden-vault.com/api/
# SECURDEN_DEBUG=true  # Activer les logs Securden (désactiver en prod)

# --- PayMe.io ---
# Clé marchand PayMe (OBLIGATOIRE en prod)
PAYME_SELLER_KEY=MPL15506-65395ZXP-LAW0B47H-ZQKDF0JS
# PAYME_BASE_URL=https://live.payme.io/api/
# PAYME_DEBUG=true

# --- CORS ---
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# --- Jobs nocturnes ---
# Activity (FireStore) à 03:00
ACTIVITY_JOB_ENABLED=true
ACTIVITY_JOB_HOUR=3
ACTIVITY_JOB_MINUTE=0
# ACTIVITY_JOB_LEASE_MS=7200000

# Analytics -> Supabase à 04:00
ANALYTICS_SYNC_JOB_ENABLED=true
ANALYTICS_SYNC_JOB_HOUR=4
ANALYTICS_SYNC_JOB_MINUTE=0
# ANALYTICS_SYNC_JOB_LEASE_MS=7200000

# PayMe (sync nextPaymentDate mensuel) — par défaut à 02:00
# Objectif: mettre à jour subscription/current pour plan.type="monthly"
# - si PayMe fournit nextPaymentDate => stocke nextPaymentDate
# - sinon => endDate = lastPaymentDate + 1 mois
PAYME_MONTHLY_NEXT_PAYMENT_SYNC_ENABLED=false
PAYME_MONTHLY_NEXT_PAYMENT_SYNC_HOUR=2
PAYME_MONTHLY_NEXT_PAYMENT_SYNC_MINUTE=0
# PAYME_MONTHLY_NEXT_PAYMENT_SYNC_LEASE_MS=7200000
# PAYME_MONTHLY_NEXT_PAYMENT_SYNC_DRY_RUN=true

# Seniority (ancienneté clients) — par défaut à 01:00
SENIORITY_JOB_ENABLED=true
SENIORITY_JOB_HOUR=1
SENIORITY_JOB_MINUTE=0
# SENIORITY_JOB_LEASE_MS=7200000

# --- Supabase (backend jobs) ---
# Recommandé: utiliser une clé service role pour bypass RLS sur les écritures de jobs
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=changeme


