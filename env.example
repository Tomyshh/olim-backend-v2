# Port du serveur
PORT=3000

# Environnement
NODE_ENV=development

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Chemin vers la clé de service Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=olimservice-7dbee-firebase-adminsdk-r13so-8e1912f7d8.json

# Bucket Firebase Storage (optionnel, détecté automatiquement depuis la clé de service)
FIREBASE_STORAGE_BUCKET=

# Configuration Vonage OTP (à ajouter quand implémenté)
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_APPLICATION_ID=

# Configuration Supabase (à ajouter quand implémenté)
# SUPABASE_URL=
# SUPABASE_KEY=

# Redis (cache QA Dashboard)
# Exemple TLS (souvent requis): rediss://default:PASSWORD@host:port
# Exemple sans TLS: redis://default:PASSWORD@host:port
REDIS_URL=

# QA Dashboard cache
QA_REDIS_TTL_SECONDS=90
QA_REDIS_LOCK_TTL_SECONDS=15
QA_COLLECTION_NAME=ChatCC
QA_SCORE_FIELD=satisfaction_score
QA_DATE_FIELD=evaluation_date
QA_DATE_TYPE=timestamp
QA_COUNSELOR_FIELD=counselorId
QA_PAGE_SIZE=1000
QA_HARD_DOC_LIMIT=20000

# Configuration FCM OAuth (à ajouter quand implémenté)
# FCM_PROJECT_ID=
# FCM_PRIVATE_KEY=
# FCM_CLIENT_EMAIL=

